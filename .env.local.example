# ============================================================
# SnapShop PWA — Environment Variables
# ============================================================
# Kopiere diese Datei zu .env.local und fülle die Werte aus.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# --- Anthropic Claude API (Rezepterkennung via Claude Vision) ---
# Key erstellen unter: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Stripe (Payment / Subscriptions) ---
# Dashboard: https://dashboard.stripe.com
# 1. Stripe Keys (Settings > API Keys)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# 2. Webhook Secret (Developers > Webhooks > Endpoint > Signing Secret)
#    Webhook-URL: https://your-domain.com/api/stripe/webhook
#    Events: checkout.session.completed, customer.subscription.*,
#            invoice.payment_succeeded, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# 3. Price IDs (Products > Your Product > Prices)
#    Erstelle ein Produkt "SnapShop Pro" mit zwei Preisen:
#    - CHF 4.90/Monat (recurring monthly)
#    - CHF 39.00/Jahr (recurring yearly)
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# --- App URL (für Stripe Redirects) ---
NEXT_PUBLIC_APP_URL=https://app.snapshop.ch

# --- Google Places (optional) ---
# GOOGLE_PLACES_API_KEY=your-key-here
